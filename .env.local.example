# Local Development Environment Configuration
# Copy this file to .env.local and customize for your local setup
# .env.local is git-ignored and won't be committed

# Override the repository URL to use your own fork
# Default: https://github.com/AmadeusITGroup/prompt-registry.git
# Example: REPO_URL="https://github.com/your-username/prompt-registry.git"
REPO_URL="https://github.com/AmadeusITGroup/prompt-registry.git"

# Override the branch to use for development
# Default: (empty - uses latest tag)
# Example: BRANCH="feature/my-feature"
# BRANCH=""
